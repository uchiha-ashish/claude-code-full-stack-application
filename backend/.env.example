NODE_ENV=development

# Local Postgres from docker-compose.yml. Start with `docker compose up -d`,
# then `npx prisma migrate dev --name init` the first time.
DATABASE_URL="postgresql://scalpscan:scalpscan@localhost:5432/scalpscan?schema=public"

PORT=4000

# Comma-separated origin allowlist. Dev-default is the Next.js dev server.
FRONTEND_ORIGIN="http://localhost:3000"

# Leave these UNSET in dev — the middleware falls through so curl-based ingest
# and the demo dashboard keep working. In production, set them per
# .env.production.example (both are REQUIRED when NODE_ENV=production).
# BECON_WEBHOOK_SECRET=
# AUTH_SIGNING_SECRET=
