NODE_ENV=production

# PostgreSQL in production — SQLite is demo-only. Encrypt at rest + enable
# point-in-time recovery at the infra layer.
DATABASE_URL="postgresql://user:password@host:5432/scalpscan?sslmode=require"

PORT=4000

# Comma-separated origin allowlist. Must be exact origins (scheme+host+port),
# no trailing slashes. The CORS middleware will reject anything not listed.
FRONTEND_ORIGIN="https://app.traya.health,https://staging-app.traya.health"

# REQUIRED in production. 32+ byte random secret shared with Becon. The webhook
# middleware rejects all /api/scans/webhook requests if unset when NODE_ENV=production.
# Generate: openssl rand -hex 32
BECON_WEBHOOK_SECRET="replace-me"

# REQUIRED in production to protect against customer-id enumeration. The app
# shell must HMAC-SHA256(`${customerId}.${isoMinute}`, secret) and pass the hex
# digest in `x-traya-signature`. Without this, the x-traya-customer-id header
# alone is a direct-object-reference. Generate: openssl rand -hex 32
AUTH_SIGNING_SECRET="replace-me"
